node_modules/
dist/
coverage/
.DS_Store
*.log
.env
.env.local
.vitest-cache/

# build artifacts
.next/
build/
out/
*.tsbuildinfo
.turbo/

# Eval sweep output — experiments aren't part of the repo (2026-05-14).
# Code/wiring/adapters/sweep YAMLs + audit docs ARE; raw summary/meta/ndjson
# from `benchmarks/runs/**` stays local. Reproduce by re-running the sweep.
benchmarks/runs/**
!benchmarks/runs/.gitkeep

# local processes / state
*.pid
observability/data/
observability/.langfuse/

# Python venv for tau-bench D5 prep (local-only)
.venv-taubench/

# Playwright MCP scratch — page snapshots, console logs, screenshots
.playwright-mcp/
*.screenshot.png

# Generated images from /api/chat create_image tool (kept ephemeral; dir tracked via .gitkeep)
src/ui/public/generated/*.png

# Report build output — entirely local. report/ is the live working
# mirror (regenerated each build); results/<YYYY-MM-DD_HHMM>/ is a
# local per-build snapshot archive. Neither tracked in git — the
# report PDF/source is a build artifact, not source-of-truth.
report/
results/

# Mastra local SQLite stores from tests
.mastra/

# Judge caches are data, not source. Each bench accumulates LLM-judge calls
# locally between runs to save API spend; not authoritative for audit.
benchmarks/*/judge_cache.json

# Ad-hoc investigation probe scripts (one-shot, not part of reproducibility).
scripts/probe-*.ts
