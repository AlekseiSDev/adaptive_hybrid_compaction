# Environment variables consumed by AHC eval harness (B2). Copy to .env.local and
# fill in real values. .env.local is gitignored.

# --- OpenRouter (vertical-slice baselines) ---
# Required for baseline=full_context (and future Track C OpenRouter-routed runners).
# Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# --- Langfuse (observability sidekick, opt-in) ---
# Master switch. Leave unset or 'false' to disable (default).
LANGFUSE_ENABLED=false
# For local self-hosted stack (observability/docker-compose.yml + LANGFUSE_INIT_*
# headless bootstrap, B4) — keys are deterministic dev values and match the
# LANGFUSE_INIT_PROJECT_PUBLIC_KEY / LANGFUSE_INIT_PROJECT_SECRET_KEY в compose.
# Production / shared deployments — override in .env.local (gitignored).
LANGFUSE_PUBLIC_KEY=pk-lf-ahc-dev-deterministic
LANGFUSE_SECRET_KEY=sk-lf-ahc-dev-deterministic
# Self-hosted (via observability/docker-compose.yml): http://localhost:3001
# Cloud: https://cloud.langfuse.com (default)
LANGFUSE_BASE_URL=http://localhost:3001
