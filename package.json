{
  "name": "ahc",
  "version": "0.0.0",
  "description": "Adaptive Hybrid Compaction — context compaction middleware for medium-distance agent trajectories",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests --exclude 'src/core/cacheInvariance.test.ts'",
    "test:cache-invariance": "vitest run --passWithNoTests src/core/cacheInvariance.test.ts",
    "verify": "./scripts/verify.sh",
    "dev:ui": "sh -c 'if [ -f ./.env ]; then set -a && . ./.env && set +a; fi; exec next dev src/ui -p \"${PORT:-3000}\" --webpack'",
    "build:ui": "sh -c 'if [ -f ./.env ]; then set -a && . ./.env && set +a; fi; exec next build src/ui --webpack'",
    "start:ui": "sh -c 'if [ -f ./.env ]; then set -a && . ./.env && set +a; fi; exec next start src/ui -p \"${PORT:-3000}\"'"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.17.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.77",
    "@ai-sdk/openai": "^3.0.63",
    "@ai-sdk/provider": "^3.0.10",
    "@ai-sdk/react": "^3.0.182",
    "@anthropic-ai/sdk": "0.95.2",
    "@google/genai": "^2.2.0",
    "@langfuse/otel": "^5.3.0",
    "@mastra/core": "1.32.1",
    "@mastra/libsql": "1.10.0",
    "@mastra/memory": "1.17.5",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "ai": "^6.0.180",
    "cheerio": "^1.2.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
