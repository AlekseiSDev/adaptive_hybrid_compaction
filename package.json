{
  "name": "ahc",
  "version": "0.0.0",
  "description": "Adaptive Hybrid Compaction — context compaction middleware for medium-distance agent trajectories",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
