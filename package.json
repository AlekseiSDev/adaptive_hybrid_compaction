    "eslint": "^9.17.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@ai-sdk/provider": "^3.0.10",
    "@anthropic-ai/sdk": "0.95.2",
    "@langfuse/otel": "^5.3.0",
